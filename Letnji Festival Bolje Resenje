#include <bits/stdc++.h>
using namespace std;

int resi(vector<vector<int>>& s, int n) {
    if (n == 0) return 0;

    sort(s.begin(), s.end());

    vector<int> dp(n);
    dp[0] = s[0][2]; 

    for (int i = 1; i < n; i++) {
        int uzmi = s[i][2]; 
        
        for (int j = i - 1; j >= 0; j--) {
            if (s[j][0] <= s[i][1]) { 
                uzmi += dp[j]; 
                break; 
            }
        }

        int ostavi = dp[i-1];
        dp[i] = max(uzmi, ostavi);
    }

    return dp[n-1];
}

int main() {
    int l_ulice, n; 
    cin >> l_ulice >> n;
    
    vector<vector<int>> s(n, vector<int>(3));
    
    for (int i = 0; i < n; i++) {
        cin >> s[i][1] >> s[i][0] >> s[i][2]; 
    }
    
    cout << resi(s, n);
}
